<configuration>

    <!-- Console -->
    <appender name="CONSOLE"
                class="ch.qos.logback.core.ConsoleAppender">

        <encoder>
            <pattern>
                %yellow(%d{HH:mm:ss}) [%cyan(%thread)|%magenta(%logger{20})] %highlight([%level]: %msg%n%ex)
            </pattern>
        </encoder>
    </appender>

    <!-- File -->
    <appender name="FILE"
                class="ch.qos.logback.core.rolling.RollingFileAppender">

        <file>logs/latest.log</file>

        <rollingPolicy
            class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">

            <fileNamePattern>
                logs/archive/app-%d{yyyy-MM-dd}.log
            </fileNamePattern>

            <maxHistory>30</maxHistory>

        </rollingPolicy>

        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss}
                [%thread]
                %-5level
                %logger{36}
                - %msg%n
            </pattern>
        </encoder>
    </appender>

    <!-- Root Logger -->
    <root level="DEBUG">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>